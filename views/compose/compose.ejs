<section class="max-w-3xl mx-auto px-4 py-10 sm:px-6 lg:px-8">
  <div class="mb-8 rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
    <div class="mb-6">
      <p class="text-sm uppercase tracking-[0.3em] text-slate-500">Buat Artikel</p>
      <h1 class="mt-3 text-3xl font-semibold text-slate-900">Tulis konten baru kamu</h1>
      <p class="mt-2 text-slate-600">Isi form berikut untuk membuat artikel baru dengan judul, ringkasan, isi, dan kategori.</p>
    </div>

    <form id="article-form"  class="space-y-6">
      <div>
        <label for="title" class="block text-sm font-medium text-slate-700">Judul</label>
        <input id="title" name="title" type="text" required class="mt-2 w-full rounded-2xl border border-slate-300 bg-slate-50 px-4 py-3 text-slate-900 outline-none focus:border-sky-500 focus:ring-2 focus:ring-sky-100" placeholder="Masukkan judul artikel" />
      </div>

      <div>
        <label for="author" class="block text-sm font-medium text-slate-700">Penulis</label>
        <input id="author" name="author" type="text" required class="mt-2 w-full rounded-2xl border border-slate-300 bg-slate-50 px-4 py-3 text-slate-900 outline-none focus:border-sky-500 focus:ring-2 focus:ring-sky-100" placeholder="Masukkan namamu" />
      </div>

     
      <div>
        <label for="summary" class="block text-sm font-medium text-slate-700">Ringkasan</label>
        <textarea id="summary" name="summary" rows="3" required class="mt-2 w-full rounded-2xl border border-slate-300 bg-slate-50 px-4 py-3 text-slate-900 outline-none focus:border-sky-500 focus:ring-2 focus:ring-sky-100" placeholder="Ringkas singkat tentang artikel"></textarea>
      </div>

      <div>
        <label for="content" class="block text-sm font-medium text-slate-700">Isi Artikel</label>
        <textarea id="content" name="content" rows="8" required class="mt-2 w-full rounded-2xl border border-slate-300 bg-slate-50 px-4 py-3 text-slate-900 outline-none focus:border-sky-500 focus:ring-2 focus:ring-sky-100" placeholder="Tulis isi artikel di sini"></textarea>
      </div>

      <div>
        <label for="category" class="block text-sm font-medium text-slate-700">Kategori</label>
        <input id="category" name="category" type="text" required class="mt-2 w-full rounded-2xl border border-slate-300 bg-slate-50 px-4 py-3 text-slate-900 outline-none focus:border-sky-500 focus:ring-2 focus:ring-sky-100" placeholder="Misalnya: Tutorial, Design, Database" />
      </div>

      <div class="flex justify-end">
        <button type="submit" class="inline-flex items-center justify-center rounded-2xl bg-sky-600 px-6 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-sky-700 focus:outline-none focus:ring-2 focus:ring-sky-400">Simpan Artikel</button>
      </div>
    </form>

    <div id="message" class="mt-4 rounded-2xl p-4 text-sm hidden"></div>
  </div>
</section>

<script>
  const form = document.getElementById('article-form');
  const message = document.getElementById('message');

  form.addEventListener('submit', async (event) => {
    event.preventDefault();

    const formData = new FormData(form);
    const body = {
      title: formData.get('title'),
      author: formData.get('author'),
      summary: formData.get('summary'),
      content: formData.get('content'),
      category: formData.get('category')
    };

    try {
      const response = await fetch('/api/articles', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify(body)
      });

      const result = await response.json();

      if (!response.ok) {
        message.className = 'mt-4 rounded-2xl border border-red-200 bg-red-50 p-4 text-sm text-red-700';
        message.textContent = result.message || 'Gagal menyimpan artikel.';
        message.classList.remove('hidden');
        return;
      }

      message.className = 'mt-4 rounded-2xl border border-emerald-200 bg-emerald-50 p-4 text-sm text-emerald-700';
      message.textContent = result.message || 'Artikel berhasil disimpan.';
      message.classList.remove('hidden');
      form.reset();
    } catch (error) {
      message.className = 'mt-4 rounded-2xl border border-red-200 bg-red-50 p-4 text-sm text-red-700';
      message.textContent = 'Terjadi kesalahan saat mengirim data.';
      message.classList.remove('hidden');
      console.error(error);
    }
  });
</script>