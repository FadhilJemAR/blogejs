<section class="max-w-7xl mx-auto px-4 py-8 sm:px-6 lg:px-8">
  <div class="mb-8 text-center">
    <p class="text-sm uppercase tracking-[0.3em] text-slate-500">Artikel Terbaru</p>
    <h1 class="mt-3 text-3xl font-semibold text-slate-900 sm:text-4xl">Temukan Artikel Menarik</h1>
    <p class="mt-2 text-base text-slate-600 sm:text-lg">Kumpulan artikel dummy yang dirender dari server dan ditampilkan dengan layout responsif.</p>
  </div>

  <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
    <% articles.forEach((article) => { %>
      <article class="relative rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-lg">
        <a class="absolute inset-0" href=<%= '/article/'+ article._id %> ></a>
        <div class="flex items-center justify-between text-sm text-slate-500">
          <span class="rounded-full bg-slate-100 px-3 py-1 font-medium"><%= article.category %></span>
          <span><%= article.date %></span>
        </div>
        <h2 class="mt-5 text-xl font-semibold text-slate-900"><%= article.title %></h2>
        <p class="mt-4 text-slate-600"><%= article.summary %></p>
        <div class="mt-6 flex items-center gap-3">
          <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-slate-100 text-slate-700"> <%= article.author.charAt(0) %> </span>
          <div>
            <p class="text-sm font-medium text-slate-900"><%= article.author %></p>
            <p class="text-sm text-slate-500">Penulis</p>
          </div>
        </div>
      </article>
    <% }) %>
  </div>
</section>