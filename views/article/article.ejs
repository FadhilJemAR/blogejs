<section class="min-h-screen bg-slate-50 py-10">
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
    <% if (!article) { %>
      <div class="rounded-3xl border border-red-200 bg-red-50 p-10 text-center shadow-sm">
        <p class="text-sm font-semibold uppercase tracking-[0.3em] text-red-600">Artikel tidak ditemukan</p>
        <h1 class="mt-4 text-3xl font-semibold text-slate-900">Maaf, artikel ini tidak tersedia.</h1>
        <p class="mt-3 text-slate-600">Pastikan link yang kamu tuju benar atau kembali ke halaman utama.</p>
        <a href="/" class="mt-8 inline-flex rounded-2xl bg-sky-600 px-5 py-3 text-sm font-semibold text-white transition hover:bg-sky-700">Kembali ke Beranda</a>
      </div>
    <% } else { %>
      <div class="rounded-[2rem] border border-slate-200 bg-white p-8 shadow-sm sm:p-12">
        <div class="mb-6 flex flex-wrap items-center gap-4 text-sm text-slate-500">
          <span class="rounded-full bg-slate-100 px-3 py-1 font-medium"><%= article.category %></span>
          <span><%= article.date %></span>
          <span>•</span>
          <span><%= article.author %></span>
        </div>

        <div class="mb-8">
          <h1 class="text-4xl font-semibold tracking-tight text-slate-900 sm:text-5xl"><%= article.title %></h1>
          <p class="mt-4 max-w-3xl text-lg leading-8 text-slate-600"><%= article.summary  %></p>
        </div>

        <div class="space-y-8 text-slate-700">
          <div class="prose prose-slate max-w-none">
            <%- (article.content ? article.content.replace(/\n/g, '<br/>') : '') %>
          </div>
        </div>

        <div class="mt-10 rounded-3xl bg-slate-50 px-6 py-5 text-slate-700 shadow-sm">
          <p class="text-sm uppercase tracking-[0.3em] text-slate-500">Tentang penulis</p>
          <p class="mt-2 text-base font-semibold text-slate-900"><%= article.author %></p>
          <p class="mt-1 text-slate-600">Terbit pada <span class="font-medium text-slate-900"><%= article.date %></span></p>
        </div>

        <div class="mt-8 flex justify-start">
          <a href="/" class="inline-flex items-center rounded-2xl border border-slate-200 bg-white px-5 py-3 text-sm font-semibold text-slate-900 transition hover:bg-slate-100">← Kembali ke Beranda</a>
        </div>
      </div>
    <% } %>
  </div>
</section>